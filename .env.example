# Copy to .env and fill in. .env is gitignored — never commit real tokens.
# HuggingFace token: needed for gated models (pyannote diarization, some ASR/emotion checkpoints).
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: where downloaded model weights are cached.
# AUDIOGEAR_MODELS_DIR=./models
# HF_HOME=~/.cache/huggingface
